---
import { SITE_CONFIG } from '../data/config';
import SEO from '../components/seo/SEO.astro';
import SchemaLocalBusiness from '../components/seo/SchemaLocalBusiness.astro';
import WhatsAppBtn from '../components/WhatsAppBtn.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  article?: boolean;
  pubDate?: Date;
  modifiedDate?: Date;
  tags?: string[];
  breadcrumb?: { name: string; url: string }[];
}

const props = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEO {...props} />
    <SchemaLocalBusiness
      breadcrumb={props.breadcrumb}
    />

    <!-- Fontes: Playfair Display (display) + DM Sans (body) -->
    <!-- Carregamento assíncnico (não bloqueia renderização) -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap"
      />
    </noscript>

    <!-- Preload crítico -->
    <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />
  </head>
  <body class="font-sans antialiased text-accent bg-cream">
    <slot />
    <WhatsAppBtn />

    <!-- Google tag (gtag.js) -- carregado no final para não bloquear renderização -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FM30T2KHYE"></script>
    <script defer>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FM30T2KHYE');
    </script>
  </body>
</html>
