---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { href: '/', label: 'Home' },
  { href: '/sobre', label: 'Sobre' },
  { href: '/servicos', label: 'Serviços' },
  { href: '/blog', label: 'Blog' },
  { href: '/contato', label: 'Contato' },
];

const legalLinks = [
  { href: '/privacidade', label: 'Política de Privacidade' },
  { href: '/termos', label: 'Termos de Uso' },
];
---

<footer class="bg-accent text-white pt-24 pb-12">
  <div class="container mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-12 mb-16">
      <div class="p-10 bg-white/5 rounded-2xl hover:bg-white/10 transition-all">
        <h3 class="text-xl font-black text-white mb-4">Aluguel de Mesas e Cadeiras</h3>
        <p class="text-gray-300 leading-relaxed">
          Especialistas em locação de mesas e cadeiras para eventos de todos os portes. Atendimento rápido, seguro e profissional.
        </p>
      </div>

      <div class="p-10 bg-white/5 rounded-2xl hover:bg-white/10 transition-all">
        <h3 class="text-xl font-black text-white mb-4">Navegação</h3>
        <ul class="space-y-3">
          {footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-300 hover:text-primary hover:scale-105 active:scale-95 transition-all inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="p-10 bg-white/5 rounded-2xl hover:bg-white/10 transition-all">
        <h3 class="text-xl font-black text-white mb-4">Contato Rápido</h3>
        <ul class="space-y-3 text-gray-300">
          <li>Telefone: (11) 99999-9999</li>
          <li>Email: contato@aluguelmesascadeiras.com.br</li>
          <li>Atendimento: Segunda a Sábado, 8h às 18h</li>
        </ul>
      </div>

      <div class="p-10 bg-white/5 rounded-2xl hover:bg-white/10 transition-all">
        <h3 class="text-xl font-black text-white mb-4">Legal</h3>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-gray-300 hover:text-primary hover:scale-105 active:scale-95 transition-all inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 text-center">
      <p class="text-gray-400 text-sm">
        © {currentYear} Aluguel de Mesas e Cadeiras. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
