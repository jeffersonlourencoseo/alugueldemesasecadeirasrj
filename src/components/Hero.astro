---
interface Props {
  title?: string;
  subtitle?: string;
  tag?: string;
}

const {
  title = 'Aluguel de Mesas e Cadeiras para o Seu Evento Perfeito',
  subtitle = 'Oferecemos as melhores opções em mesas e cadeiras para festas, eventos corporativos e celebrações. Entrega rápida, montagem profissional e preços justos.',
  tag = '🏆 Líder em Aluguel de Mesas e Cadeiras',
} = Astro.props;

const phone = '5511999999999';
const message = 'Olá! Gostaria de fazer um orçamento para aluguel de mesas e cadeiras.';
const waLink = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<section class="relative overflow-hidden bg-secondary py-24 md:py-32">
  <div class="container mx-auto px-6 md:px-12 relative z-10">
    <div class="max-w-4xl">
      <span class="inline-block px-4 py-2 text-sm font-black text-accent bg-primary rounded-full mb-6">
        {tag}
      </span>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight text-white mb-10">
        {title}
      </h1>

      <p class="text-lg md:text-xl text-gray-100 max-w-3xl leading-relaxed mb-10">
        {subtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-10">
        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-accent bg-primary rounded-full hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
        >
          📱 Solicitar Orçamento no WhatsApp
        </a>
        <a
          href="/servicos"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white border-2 border-white rounded-full hover:bg-white hover:text-secondary hover:scale-105 active:scale-95 transition-all"
        >
          Ver Nossos Equipamentos
        </a>
      </div>
    </div>
  </div>

  <div class="absolute inset-0 bg-gradient-to-br from-secondary via-secondary to-blue-950 opacity-90"></div>
  <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-primary rounded-full blur-3xl opacity-20"></div>
</section>
