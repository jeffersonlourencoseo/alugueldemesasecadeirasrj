---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const servicos = await getCollection('servicos');

import { SITE_CONFIG } from '../../data/config';

const waLink = SITE_CONFIG.social.whatsappLink;
---

<Layout title="Serviços | Aluguel de Mesas e Cadeiras">
  <Header />

  <main>
    <section class="py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-gray-900 mb-16 max-w-4xl text-center md:text-left">
          Nossos Serviços de Aluguel
        </h1>

        <div class="flex flex-col lg:flex-row gap-10 md:gap-12">
          <!-- LISTAGEM -->
          <div class="flex-1">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12">
              {servicos.map((servico) => (
                <article class="p-10 md:p-12 bg-gray-50 rounded-2xl border border-gray-100 hover:shadow-xl hover:scale-105 active:scale-95 transition-all flex flex-col">
                  <h2 class="text-2xl font-black text-gray-900 mb-4">
                    {servico.data.title}
                  </h2>
                  <p class="text-gray-600 leading-relaxed mb-6 flex-grow">
                    {servico.data.description}
                  </p>
                  {servico.data.price && (
                    <p class="text-xl font-black text-secondary mb-6">
                      {servico.data.price}
                    </p>
                  )}
                  <a
                    href={`/servicos/${servico.slug}`}
                    class="inline-flex items-center justify-center w-full p-6 text-lg font-bold text-accent bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
                  >
                    Ver Detalhes
                  </a>
                </article>
              ))}
            </div>
          </div>

          <!-- SIDEBAR CTA -->
          <aside class="lg:w-96 flex-shrink-0">
            <div class="sticky top-28 p-10 md:p-12 bg-secondary rounded-2xl text-white">
              <h3 class="text-2xl font-black text-primary mb-4">
                Precisa de um Orçamento?
              </h3>
              <p class="text-gray-200 leading-relaxed mb-8">
                Fale com nossa equipe agora mesmo pelo WhatsApp e receba um orçamento rápido e sem compromisso.
              </p>
              <a
                href={waLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center w-full p-6 text-lg font-bold text-accent bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-primary/30"
              >
                📱 Pedir Orçamento
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
