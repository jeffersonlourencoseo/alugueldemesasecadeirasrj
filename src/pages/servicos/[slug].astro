---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const servicos = await getCollection('servicos');
  return servicos.map((servico) => ({
    params: { slug: servico.slug },
    props: { servico },
  }));
}

const { servico } = Astro.props;
const { Content } = await servico.render();

import { SITE_CONFIG } from '../../data/config';

const waLink = SITE_CONFIG.social.whatsappLink;
---

<Layout title={`${servico.data.title} | Aluguel de Mesas e Cadeiras`}>
  <Header />

  <main>
    <!-- HERO DO SERVIÇO -->
    <section class="relative overflow-hidden bg-secondary py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12 relative z-10">
        <div class="max-w-4xl">
          <span class="inline-block px-4 py-2 text-sm font-black text-accent bg-primary rounded-full mb-6">
            Nossos Equipamentos
          </span>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight text-white mb-6">
            {servico.data.title}
          </h1>

          <p class="text-lg md:text-xl text-gray-100 max-w-3xl leading-relaxed mb-10">
            {servico.data.description}
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mt-10">
            <a
              href={waLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-accent bg-primary rounded-full hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
            >
              📱 Solicitar Orçamento no WhatsApp
            </a>
            <a
              href="/servicos"
              class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-white border-2 border-white rounded-full hover:bg-white hover:text-secondary hover:scale-105 active:scale-95 transition-all"
            >
              Ver Todos os Equipamentos
            </a>
          </div>
        </div>
      </div>

      <div class="absolute inset-0 bg-gradient-to-br from-secondary via-secondary to-blue-950 opacity-90"></div>
      <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-primary rounded-full blur-3xl opacity-20"></div>
    </section>

    <section class="py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <div class="flex flex-col lg:flex-row gap-10 md:gap-12">
          <!-- CONTEÚDO -->
          <div class="flex-1">
            <div class="max-w-5xl">
              <article class="prose prose-lg md:prose-xl">
                {servico.data.features.length > 0 && (
                  <div class="p-10 md:p-12 bg-gray-50 rounded-2xl mb-12 not-prose">
                    <h2 class="text-2xl font-black text-gray-900 mb-6">O que está incluído</h2>
                    <ul class="space-y-4">
                      {servico.data.features.map((feature) => (
                        <li class="flex items-start gap-3">
                          <span class="inline-block w-2 h-2 mt-2.5 bg-primary rounded-full flex-shrink-0"></span>
                          <span class="text-gray-700 text-lg">{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div class="mt-12">
                  <Content />
                </div>

                <div class="mt-16 not-prose">
                  <a
                    href={waLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-10 py-5 text-lg font-bold text-accent bg-primary rounded-full hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
                  >
                    📱 Solicitar Orçamento no WhatsApp
                  </a>
                </div>
              </article>
            </div>
          </div>

          <!-- SIDEBAR CTA -->
          <aside class="lg:w-96 flex-shrink-0">
            <div class="sticky top-28 p-10 md:p-12 bg-secondary rounded-2xl text-white">
              <h3 class="text-2xl font-black text-primary mb-4">
                Gostou do {servico.data.title}?
              </h3>
              <p class="text-gray-200 leading-relaxed mb-8">
                Solicite um orçamento gratuito agora mesmo pelo WhatsApp. Atendimento rápido e preço justo.
              </p>
              <a
                href={waLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center w-full p-6 text-lg font-bold text-accent bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-primary/30"
              >
                📱 Pedir Orçamento
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
