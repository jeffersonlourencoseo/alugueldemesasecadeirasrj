---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_CONFIG } from '../data/config';

const { nap, social } = SITE_CONFIG;
const waLink = social.whatsappLink;
---

<Layout title="Contato | Aluguel de Mesas e Cadeiras">
  <Header />

  <main>
    <section class="py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <span class="inline-block px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-primary border border-primary/20 rounded-full mb-6">
          Fale Conosco
        </span>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-accent mb-16 max-w-4xl">
          Entre em Contato e Solicite seu Orçamento
        </h1>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-12">
          <!-- NAP + INFORMAÇÕES -->
          <article class="p-10 bg-white border border-border-subtle rounded-2xl">
            <h2 class="font-display text-2xl font-bold text-accent mb-8">Informações de Contato</h2>

            <ul class="space-y-8">
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 border border-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-accent text-sm uppercase tracking-wider">Telefone</p>
                  <a href={`tel:${nap.phone}`} class="text-accent/60 hover:text-secondary transition-colors">
                    {nap.phoneDisplay}
                  </a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 border border-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-accent text-sm uppercase tracking-wider">Email</p>
                  <a href={`mailto:${nap.email}`} class="text-accent/60 hover:text-secondary transition-colors break-all">
                    {nap.email}
                  </a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 border border-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-accent text-sm uppercase tracking-wider">Horário de Atendimento</p>
                  <p class="text-accent/60">Segunda a Sábado, 8h às 18h</p>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary/10 border border-primary/20 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-accent text-sm uppercase tracking-wider">Endereço</p>
                  <p class="text-accent/60">
                    {nap.address} - {nap.addressComplement}<br />
                    {nap.city}, {nap.state} - CEP {nap.postalCode}
                  </p>
                </div>
              </li>
            </ul>

            <div class="mt-10 p-8 bg-secondary rounded-2xl text-white relative overflow-hidden">
              <!-- Grain -->
              <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

              <div class="relative z-10">
                <h3 class="font-display text-xl font-bold text-primary mb-4">Atendimento Rápido pelo WhatsApp</h3>
                <p class="text-white/60 mb-6">
                  Clique no botão abaixo e fale diretamente com nossa equipe.
                </p>
                <a
                  href={waLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 w-full p-5 text-base font-bold uppercase tracking-wider text-secondary bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Falar no WhatsApp
                </a>
              </div>
            </div>
          </article>

          <!-- FORMULÁRIO -->
          <form class="p-10 bg-white border border-border-subtle rounded-2xl shadow-sm space-y-6">
            <h2 class="font-display text-2xl font-bold text-accent mb-8">Solicitar Orçamento</h2>

            <div>
              <label for="nome" class="block text-sm font-bold uppercase tracking-wider text-accent mb-2">Nome completo</label>
              <input
                type="text"
                id="nome"
                name="nome"
                required
                class="w-full p-5 text-base bg-cream border border-border-subtle rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all"
                placeholder="Seu nome"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-bold uppercase tracking-wider text-accent mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full p-5 text-base bg-cream border border-border-subtle rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all"
                placeholder="seu@email.com"
              />
            </div>

            <div>
              <label for="telefone" class="block text-sm font-bold uppercase tracking-wider text-accent mb-2">Telefone</label>
              <input
                type="tel"
                id="telefone"
                name="telefone"
                required
                class="w-full p-5 text-base bg-cream border border-border-subtle rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all"
                placeholder="(21) 99775-1577"
              />
            </div>

            <div>
              <label for="mensagem" class="block text-sm font-bold uppercase tracking-wider text-accent mb-2">Mensagem</label>
              <textarea
                id="mensagem"
                name="mensagem"
                rows="5"
                required
                class="w-full p-5 text-base bg-cream border border-border-subtle rounded-xl focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary resize-none transition-all"
                placeholder="Descreva o que você precisa (tipo de evento, quantidade de mesas e cadeiras, data, local...)"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full p-5 text-base font-bold uppercase tracking-wider text-secondary bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
            >
              Enviar Solicitação
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
