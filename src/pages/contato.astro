---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_CONFIG } from '../data/config';

const { nap, social } = SITE_CONFIG;
const waLink = social.whatsappLink;
---

<Layout title="Contato | Aluguel de Mesas e Cadeiras">
  <Header />

  <main>
    <section class="py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-gray-900 mb-16 max-w-4xl">
          Entre em Contato e Solicite seu Orçamento
        </h1>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-12">
          <!-- NAP + INFORMAÇÕES -->
          <article class="p-10 md:p-12 bg-gray-50 rounded-2xl">
            <h2 class="text-2xl font-black text-gray-900 mb-8">Informações de Contato</h2>

            <ul class="space-y-8">
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-black text-gray-900">Telefone</p>
                  <a href={`tel:${nap.phone}`} class="text-gray-600 hover:text-secondary transition-colors">
                    {nap.phoneDisplay}
                  </a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-black text-gray-900">Email</p>
                  <a href={`mailto:${nap.email}`} class="text-gray-600 hover:text-secondary transition-colors">
                    {nap.email}
                  </a>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-black text-gray-900">Horário de Atendimento</p>
                  <p class="text-gray-600">Segunda a Sábado, 8h às 18h</p>
                </div>
              </li>

              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-black text-gray-900">Endereço</p>
                  <p class="text-gray-600">
                    {nap.address} - {nap.addressComplement}<br />
                    {nap.city}, {nap.state} - CEP {nap.postalCode}
                  </p>
                </div>
              </li>
            </ul>

            <div class="mt-10 p-8 bg-secondary rounded-2xl text-white">
              <h3 class="text-xl font-black text-primary mb-4">Atendimento Rápido pelo WhatsApp</h3>
              <p class="text-gray-200 mb-6">
                Clique no botão abaixo e fale diretamente com nossa equipe.
              </p>
              <a
                href={waLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center w-full p-6 text-lg font-bold text-accent bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
              >
                📱 Falar no WhatsApp
              </a>
            </div>
          </article>

          <!-- FORMULÁRIO -->
          <form class="p-10 md:p-12 bg-white rounded-2xl border border-gray-200 shadow-sm space-y-6">
            <h2 class="text-2xl font-black text-gray-900 mb-8">Solicitar Orçamento</h2>

            <div>
              <label for="nome" class="block text-sm font-black text-gray-900 mb-2">Nome completo</label>
              <input
                type="text"
                id="nome"
                name="nome"
                required
                class="w-full p-6 text-lg bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                placeholder="Seu nome"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-black text-gray-900 mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full p-6 text-lg bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                placeholder="seu@email.com"
              />
            </div>

            <div>
              <label for="telefone" class="block text-sm font-black text-gray-900 mb-2">Telefone</label>
              <input
                type="tel"
                id="telefone"
                name="telefone"
                required
                class="w-full p-6 text-lg bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                placeholder="(21) 99775-1577"
              />
            </div>

            <div>
              <label for="mensagem" class="block text-sm font-black text-gray-900 mb-2">Mensagem</label>
              <textarea
                id="mensagem"
                name="mensagem"
                rows="5"
                required
                class="w-full p-6 text-lg bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none transition-all"
                placeholder="Descreva o que você precisa (tipo de evento, quantidade de mesas e cadeiras, data, local...)"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full p-6 text-lg font-bold text-accent bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
            >
              Enviar Solicitação
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
