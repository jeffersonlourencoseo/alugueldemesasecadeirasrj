---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_CONFIG } from '../../data/config';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog | Aluguel de Mesas e Cadeiras">
  <Header />

  <main>
    <section class="py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-gray-900 mb-6">
            Blog com Dicas e Novidades
          </h1>
          <p class="text-lg text-gray-600 leading-relaxed">
            Conteúdo exclusivo para ajudar você a planejar o evento perfeito.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 mb-24">
          {sortedPosts.map((post) => (
            <article class="p-10 md:p-12 bg-gray-50 rounded-2xl border border-gray-100 hover:shadow-xl hover:scale-105 active:scale-95 transition-all flex flex-col">
              <time class="text-sm font-black text-secondary mb-4">
                {post.data.pubDate.toLocaleDateString('pt-BR', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>

              <h2 class="text-2xl font-black text-gray-900 mb-4">
                <a href={`/blog/${post.slug}`} class="hover:text-secondary hover:scale-105 active:scale-95 transition-all inline-block">
                  {post.data.title}
                </a>
              </h2>

              <p class="text-gray-600 leading-relaxed mb-6 flex-grow">
                {post.data.description}
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {post.data.tags.map((tag) => (
                  <span class="px-3 py-1 text-sm font-black bg-white border border-gray-200 rounded-full text-gray-600">
                    {tag}
                  </span>
                ))}
              </div>

              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center justify-center w-full p-6 text-lg font-bold text-accent bg-primary rounded-xl hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
              >
                Ler Artigo
              </a>
            </article>
          ))}
        </div>

        <div class="max-w-4xl mx-auto p-10 md:p-12 bg-secondary rounded-3xl text-center">
          <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-primary mb-6">
            Precisa de Ajuda para Planejar seu Evento?
          </h2>
          <p class="text-lg text-gray-100 leading-relaxed mb-8 max-w-2xl mx-auto">
            Nossa equipe está pronta para tirar suas dúvidas e ajudar na escolha certa de mesas e cadeiras.
          </p>
          <a
            href={SITE_CONFIG.social.whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-10 py-5 text-lg font-bold text-accent bg-primary rounded-full hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
          >
            📱 Falar com um Especialista
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
