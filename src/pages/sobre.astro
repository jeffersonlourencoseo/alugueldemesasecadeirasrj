---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Sobre Nós | Aluguel de Mesas e Cadeiras">
  <Header />

  <main>
    <section class="py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-gray-900 mb-16 max-w-4xl">
          Sobre a Nossa Empresa de Aluguel de Mesas e Cadeiras
        </h1>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-12 mb-24">
          <article class="p-10 md:p-12 bg-gray-50 rounded-2xl hover:shadow-xl hover:scale-[1.01] transition-all">
            <h2 class="text-2xl font-black text-gray-900 mb-6">Nossa História</h2>
            <p class="text-gray-600 leading-relaxed mb-6">
              Somos uma empresa especializada no aluguel de mesas e cadeiras para eventos de todos os portes. Atuamos há mais de 10 anos no mercado, oferecendo qualidade, pontualidade e preços justos.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Nosso compromisso é tornar seu evento perfeito, cuidando de cada detalhe na entrega, montagem e retirada dos equipamentos. Começamos como uma pequena operação familiar e hoje atendemos toda a região metropolitana com uma frota moderna e equipe treinada.
            </p>
          </article>

          <article class="p-10 md:p-12 bg-gray-50 rounded-2xl hover:shadow-xl hover:scale-[1.01] transition-all">
            <h2 class="text-2xl font-black text-gray-900 mb-6">Missão e Valores</h2>
            <ul class="space-y-4 text-gray-600">
              <li class="flex items-start gap-3">
                <span class="inline-block w-2 h-2 mt-2 bg-primary rounded-full flex-shrink-0"></span>
                <span>Oferecer o melhor atendimento e equipamentos de qualidade</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="inline-block w-2 h-2 mt-2 bg-primary rounded-full flex-shrink-0"></span>
                <span>Pontualidade na entrega e montagem</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="inline-block w-2 h-2 mt-2 bg-primary rounded-full flex-shrink-0"></span>
                <span>Preços justos e transparentes</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="inline-block w-2 h-2 mt-2 bg-primary rounded-full flex-shrink-0"></span>
                <span>Higienização e manutenção constante dos equipamentos</span>
              </li>
            </ul>
          </article>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="p-10 bg-gray-50 rounded-2xl text-center hover:shadow-lg hover:scale-105 active:scale-95 transition-all">
            <p class="text-4xl md:text-5xl font-black text-secondary mb-2">10+</p>
            <p class="text-gray-600 font-medium">Anos no Mercado</p>
          </div>
          <div class="p-10 bg-gray-50 rounded-2xl text-center hover:shadow-lg hover:scale-105 active:scale-95 transition-all">
            <p class="text-4xl md:text-5xl font-black text-secondary mb-2">5.000+</p>
            <p class="text-gray-600 font-medium">Eventos Realizados</p>
          </div>
          <div class="p-10 bg-gray-50 rounded-2xl text-center hover:shadow-lg hover:scale-105 active:scale-95 transition-all">
            <p class="text-4xl md:text-5xl font-black text-secondary mb-2">98%</p>
            <p class="text-gray-600 font-medium">Aprovação dos Clientes</p>
          </div>
          <div class="p-10 bg-gray-50 rounded-2xl text-center hover:shadow-lg hover:scale-105 active:scale-95 transition-all">
            <p class="text-4xl md:text-5xl font-black text-secondary mb-2">2h</p>
            <p class="text-gray-600 font-medium">Entrega Rápida</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
