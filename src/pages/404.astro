---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página Não Encontrada | Aluguel de Mesas e Cadeiras" noindex>
  <Header />

  <main>
    <section class="py-24 md:py-32">
      <div class="container mx-auto px-6 md:px-12 text-center">
        <p class="font-display text-8xl md:text-9xl font-bold text-secondary mb-6">404</p>
        <div class="w-16 h-[2px] bg-primary mx-auto mb-8"></div>
        <p class="text-xl md:text-2xl text-accent/60 mb-10">
          Opa! Parece que esta página não existe mais.
        </p>
        <a
          href="/"
          class="inline-flex items-center justify-center px-10 py-5 text-base font-bold uppercase tracking-wider text-secondary bg-primary rounded-full hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
        >
          Voltar para a Home
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
